APP_ENV=dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:55432/habeas_tracker

# Retrieval source (configurable so you can swap providers)
RETRIEVAL_BASE_URL=https://www.courtlistener.com
RETRIEVAL_SEARCH_PATH=/api/rest/v4/search/
RETRIEVAL_API_KEY=

# Polling
POLL_QUERY="habeas 1225 1226 \"mandatory detention\" \"bond hearing\""
POLL_LOOKBACK_DAYS=14
POLL_MAX_RESULTS=25

ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_MINUTES=30
EXTRACTION_BATCH_LIMIT=50
AUTO_REVIEW_CONFIDENCE_THRESHOLD=0.45
REQUIRE_OPINION_TEXT_FOR_AUTO_EXTRACT=false